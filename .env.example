# Gestão à Vista — variáveis de ambiente
# Copie para .env (ou exporte no ambiente) e preencha com seus valores.
# Sem nenhuma variável definida, o projeto sobe em modo desenvolvimento:
# SQLite local, DEBUG ligado e e-mails impressos no console.

# --- Django ---
DJANGO_SECRET_KEY=gere-uma-chave-forte-aqui
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# URL pública usada para montar links absolutos (QR Codes do Livro Ata etc.)
SITE_URL=http://localhost:8000

# --- Banco de dados (opcional — sem POSTGRES_HOST, usa SQLite) ---
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=gestao_a_vista
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Réplica somente-leitura para relatórios (opcional — aponte para o mesmo
# banco se não houver réplica)
READONLY_HOST=
READONLY_DB=

# --- E-mail (opcional — sem EMAIL_HOST_USER, usa backend de console) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# --- Notificações WhatsApp via uazapi (opcional) ---
UAZAPI_BASE_URL=
UAZAPI_INSTANCE_TOKEN=
UAZAPI_ADMIN_TOKEN=
LIVRO_ATA_NOTIFICACAO_NUMERO_TESTE=

# --- Integração com o dashboard financeiro (Streamlit) ---
FINANCEIRO_URL=http://localhost:8501
