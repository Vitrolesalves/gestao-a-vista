          "country_name": {
            "type": "keyword"
          },
          "country_code2": {
            "type": "keyword"
          },
          "country_code3": {
            "type": "keyword"
          },
          "region_name": {
            "type": "keyword"
          },
          "region_code": {
            "type": "keyword"
          },
          "city_name": {
            "type": "keyword"
          },
          "postal_code": {
            "type": "keyword"
